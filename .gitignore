# macOS
.DS_Store

# Internal design/brainstorm docs (kept locally, not published)
docs/superpowers/

# Logs (the routine writes to ~/Library/Logs, but ignore any stray local logs)
*.log

# Secrets: real webhook URLs live in ~/.config/alibi-to-5/secrets, but never
# commit a local copy. The tracked template is secrets.example.
secrets
!secrets.example
