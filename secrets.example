# alibi-to-5 secrets — webhook URLs for the good-morning message.
#
# Copy this to ~/.config/alibi-to-5/secrets (NOT into the repo) and fill in your
# real URL(s). The routine sources this file at wake; the values never leave your
# machine and are never committed.
#
#   mkdir -p ~/.config/alibi-to-5
#   cp secrets.example ~/.config/alibi-to-5/secrets
#   chmod 600 ~/.config/alibi-to-5/secrets
#
# Only the URL for your chosen --gm-platform is needed (slack or teams).

# Slack incoming webhook (https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=""

# Microsoft Teams incoming webhook / Workflows URL
TEAMS_WEBHOOK_URL=""
