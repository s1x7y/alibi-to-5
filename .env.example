# alibi-to-5 config — override any default without editing the script.
#
# Copy this to ~/.config/alibi-to-5/.env (NOT into the repo) and uncomment what
# you want. It is sourced as shell at load, after the script's defaults, so a
# line here wins over the script; flags on 'set'/'test' win over both. Values
# never leave your machine and are never committed.
#
#   mkdir -p ~/.config/alibi-to-5
#   cp .env.example ~/.config/alibi-to-5/.env
#   chmod 600 ~/.config/alibi-to-5/.env

# ---- Feature toggles (all off by default) ----------------------------------
#ENABLE_SLACK=1          # open Slack.app at wake
#ENABLE_TEAMS=1          # open Microsoft Teams.app at wake
#ENABLE_CODEX=1          # ping the Codex CLI to start its usage window
#ENABLE_CLAUDE=1         # ping the Claude CLI to start its usage window
#ENABLE_HOLIDAY_SKIP=1   # skip public holidays (needs COUNTRY_CODE)

# ---- Workday shape ----------------------------------------------------------
#WORK_END="18:00"        # end-of-day; unset = ~9h after wake
#LUNCH_START="13:00"     # jittered lunch gap; unset = no lunch
#LUNCH_MINUTES=45
#COUNTRY_CODE="PT"       # ISO-3166 alpha-2, for the holiday lookup
#EXTRA_SKIP_DATES=(2026-12-24 2026-12-31)   # manual PTO / one-offs

# ---- Good-morning webhook (secret: keep this file chmod 600) ----------------
#GOOD_MORNING_TEXT="Online {day} {time}"
#GOOD_MORNING_PLATFORM="slack"   # slack | teams
#SLACK_WEBHOOK_URL=""    # https://api.slack.com/messaging/webhooks
#TEAMS_WEBHOOK_URL=""    # Teams incoming webhook / Workflows URL
